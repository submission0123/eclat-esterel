module ABCDERO:
  input A, B, C, D, E, R;
  output O;
  signal ABC in
    [ run ABCRO [ signal ABC / O ] ||
      run ABCRO [ signal ABC / A, D / B, E / C ] ]
  end

end module


  %||
  %   run ABCRO [ signal ABC / A, D / B, E / C ]
 % end
 %
    % loop
   %   [ await A || await B || await C || await D || await E || await R]; emit O end
